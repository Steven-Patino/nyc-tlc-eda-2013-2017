# Copia este archivo como .env y ajusta las rutas segun tu equipo.
# El archivo .env real no se sube a Git.

# Puedes usar rutas absolutas o relativas al proyecto.
NYC_TLC_RAW_DATA_DIR=raw_datasets
NYC_TLC_OUTPUT_DIR=outputs/new_datasets

# Numero de filas que se procesan por lote durante la unificacion.
# Reduce este valor si tu equipo tiene poca RAM.
NYC_TLC_BATCH_SIZE=250000
